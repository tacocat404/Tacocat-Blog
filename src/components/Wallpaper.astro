---
// 사계절 애니메이션 배경화면. 네 계절을 모두 렌더하고,
// Desktop.astro의 계절 감지 JS가 body[data-season]으로 하나만 보이게 한다.
const rnd = (a: number, b: number) => a + Math.random() * (b - a);
type P = { left: number; delay: number; dur: number; size: number; dx: number; rot: number };
const make = (n: number, opt: { dur: [number, number]; size: [number, number]; dx: [number, number]; rot: [number, number] }): P[] =>
  Array.from({ length: n }, () => ({
    left: rnd(0, 100),
    delay: -rnd(0, opt.dur[1]),
    dur: rnd(opt.dur[0], opt.dur[1]),
    size: Math.round(rnd(opt.size[0], opt.size[1])),
    dx: Math.round(rnd(opt.dx[0], opt.dx[1])),
    rot: Math.round(rnd(opt.rot[0], opt.rot[1])),
  }));

const petals = make(26, { dur: [7, 13], size: [4, 7], dx: [-40, -110], rot: [120, 360] });
const leaves = make(22, { dur: [7, 13], size: [5, 8], dx: [-50, -130], rot: [180, 540] });
const snow = make(34, { dur: [8, 16], size: [3, 6], dx: [-20, 30], rot: [0, 0] });

const pstyle = (p: P) =>
  `left:${p.left}%;width:${p.size}px;height:${p.size}px;--dur:${p.dur}s;--delay:${p.delay}s;--dx:${p.dx}px;--rot:${p.rot}deg;`;
---

<!-- ===== 봄 ===== -->
<div class="wp" data-wp="spring">
  <svg class="scene" viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice" shape-rendering="crispEdges">
    <rect x="0" y="0" width="400" height="300" fill="#eef0df" />
    <rect x="0" y="0" width="400" height="105" fill="#f4dfe9" />
    <rect x="0" y="105" width="400" height="45" fill="#efe7e6" />
    <rect x="0" y="150" width="400" height="30" fill="#e9ead9" />
    <circle cx="350" cy="52" r="30" fill="#f9ecd0" />
    <circle cx="350" cy="52" r="22" fill="#fbe6b6" />
    <g class="cloud" style="--cdur:46s">
      <rect x="70" y="60" width="70" height="16" fill="#fff" /><rect x="86" y="50" width="44" height="12" fill="#fff" /><rect x="56" y="70" width="98" height="10" fill="#fff" />
    </g>
    <g class="cloud" style="--cdur:64s;--cdelay:-20s">
      <rect x="240" y="96" width="58" height="14" fill="#fff" /><rect x="256" y="88" width="34" height="10" fill="#fbf3f6" />
    </g>
    <rect x="0" y="196" width="400" height="42" fill="#bcd6a4" />
    <rect x="0" y="196" width="400" height="8" fill="#cde4b4" />
    <rect x="0" y="230" width="400" height="70" fill="#a3c48a" />
    <rect x="0" y="230" width="400" height="8" fill="#b6d49b" />
    <rect x="0" y="272" width="400" height="28" fill="#8bb173" />
    <g>
      <rect x="286" y="150" width="12" height="58" fill="#8a6a52" />
      <rect x="252" y="116" width="82" height="40" fill="#f4c2d4" />
      <rect x="242" y="132" width="102" height="28" fill="#f3b8cd" />
      <rect x="266" y="104" width="56" height="20" fill="#f8d5e1" />
    </g>
  </svg>
  <div class="fx">{petals.map((p) => <span class="petal" style={pstyle(p)} />)}</div>
</div>

<!-- ===== 여름 ===== -->
