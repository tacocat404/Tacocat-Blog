---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";
import { catInfo } from "../../config/study";

export async function getStaticPaths() {
  const posts = await getCollection("study");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const cat = catInfo(post.data.category);
// 독서 글: 본문을 명조체 타이포그래피(prose--book)로, KaTeX 대신 명조 폰트 로드
const isBook = post.data.category === "독서";
---

<Base
  title={`${post.data.title} - 공부기록 · Alien Cat OS`}
  description={post.data.summary}
  math={!isBook}
  serif={isBook}
>
  <div class="browser-desk">
    <div class="browser">
      <header class="titlebar">
        <span class="dot-r"></span><span class="dot-y"></span>
        <span class="t">공부기록.exe - {post.data.title}</span>
        <a class="x" href="/?open=study" aria-label="닫기">x</a>
      </header>
      <div class="toolbar">
        <a class="nav-btn" href="/?open=study" aria-label="뒤로">◀</a>
        <span class="nav-btn dis" aria-hidden="true">▶</span>
        <span class="addr">aliencat://study/{post.id}</span>
      </div>
      <article class="page-body">
        <div class="post-meta">
          <span class="cat-badge" style={`background:${cat.color}`}>{post.data.category}</span>
          {post.data.series && (
            <span class="series-badge">
              ▙ {post.data.series}{post.data.seriesOrder != null ? ` #${post.data.seriesOrder}` : ""}
            </span>
          )}
          <span class="date">{post.data.date}</span>
        </div>
        <h1 class="post-title">{post.data.title}</h1>
        {post.data.bookInfo && <p class="book-info">📖 {post.data.bookInfo}</p>}
        {post.data.summary && <p class="post-summary">{post.data.summary}</p>}
        <div class="tags">
          {post.data.tags.map((x) => <span class="tag">#{x}</span>)}
        </div>
        <hr class="rule" />
        <div class={isBook ? "prose prose--book" : "prose"}>
          <Content />
        </div>

        {post.data.music.length > 0 && (
          <section class="music" aria-label="함께 들은 노래">
            <h2 class="music-title">📼 함께 들은 노래</h2>
            <ul class="music-list">
              {post.data.music.map((m) => (
                <li class="cassette">
                  <div class="cassette-shell">
                    <div class="cassette-window">
                      <span class="reel" aria-hidden="true"></span>
                      <span class="tape-line" aria-hidden="true"></span>
                      <span class="reel" aria-hidden="true"></span>
                    </div>
                    <div class="cassette-label">
                      <span class="song-title">{m.title}</span>
                      {m.artist && <span class="song-artist">{m.artist}</span>}
                    </div>
                  </div>
                  <div class="music-meta">
                    {m.note && <span class="music-note">♪ {m.note}</span>}
                    {m.url && (
                      <a class="music-play" href={m.url} target="_blank" rel="noopener noreferrer">
                        ▶ 듣기
                      </a>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </section>
        )}

        {post.data.attachments.length > 0 && (
          <section class="attachments" aria-label="첨부파일">
            <h2 class="attach-title">📎 첨부파일 — 손필기 원본</h2>
            <ul class="attach-list">
              {post.data.attachments.map((a) => (
                <li class="attach-item">
                  <button
                    type="button"
                    class="attach-thumb"
                    data-src={a.file}
                    data-kind={a.kind}
                    data-label={a.label}
                    aria-label={`${a.label} 미리보기`}
                  >
                    {a.kind === "image" ? (
                      <img src={a.file} alt={a.label} loading="lazy" decoding="async" />
                    ) : (
                      <span class="attach-fileicon">PDF</span>
                    )}
                    <span class="attach-zoom">🔍 미리보기</span>
                  </button>
                  <div class="attach-meta">
                    <span class="attach-label">{a.label}</span>
                    <a class="attach-dl" href={a.file} download>⬇ 다운로드</a>
                  </div>
                </li>
              ))}
            </ul>
          </section>
        )}

        <hr class="rule" />
        <footer class="post-footer">
          <a class="start-btn" href="/?open=study"><span class="dot"></span>목록으로</a>
          <a class="start-btn" href="/"><span class="dot"></span>바탕화면</a>
        </footer>
      </article>
    </div>
  </div>

  <div class="lightbox" id="lightbox" hidden>
    <div class="lb-titlebar">
      <span class="lb-name" id="lb-name"></span>
      <a class="lb-dl" id="lb-dl" href="#" download>⬇ 다운로드</a>
      <button type="button" class="lb-x" id="lb-x" aria-label="닫기">x</button>
    </div>
    <div class="lb-stage" id="lb-stage"></div>
  </div>
</Base>

<script>
  const lb = document.getElementById("lightbox");
  const stage = document.getElementById("lb-stage");
  const nameEl = document.getElementById("lb-name");
  const dlEl = document.getElementById("lb-dl");

  function openLightbox(src: string, kind: string, label: string) {
    if (!lb || !stage || !nameEl || !dlEl) return;
    stage.innerHTML = "";
    if (kind === "pdf") {
      const frame = document.createElement("iframe");
      frame.src = src;
      frame.title = label || "미리보기";
      stage.appendChild(frame);
    } else {
      const img = document.createElement("img");
      img.src = src;
      img.alt = label || "미리보기";
      stage.appendChild(img);
    }
    nameEl.textContent = label || "";
    dlEl.setAttribute("href", src);
    lb.hidden = false;
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    if (!lb || !stage) return;
    lb.hidden = true;
    stage.innerHTML = "";
    document.body.style.overflow = "";
  }

  document.querySelectorAll(".attach-thumb").forEach((btn) => {
    btn.addEventListener("click", () => {
      openLightbox(
        btn.getAttribute("data-src") || "",
        btn.getAttribute("data-kind") || "image",
        btn.getAttribute("data-label") || "",
      );
    });
  });

  document.getElementById("lb-x")?.addEventListener("click", closeLightbox);
  lb?.addEventListener("click", (e) => {
    if (e.target === lb) closeLightbox();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lb && !lb.hidden) closeLightbox();
  });
</script>

<style>
  body { overflow: auto; }

  .browser-desk {
    min-height: 100dvh;
    padding: 28px 16px 40px;
    background: var(--desktop);
    background-image:
      radial-gradient(rgba(107,84,64,.22) 1.5px, transparent 1.5px),
      radial-gradient(rgba(251,243,226,.28) 1.5px, transparent 1.5px);
    background-size: 18px 18px;
    background-position: 0 0, 9px 9px;
    display: flex; justify-content: center;
  }
  .browser {
    width: min(860px, 100%);
    background: var(--cream);
    border: 3px solid var(--ink);
    box-shadow: inset 2px 2px 0 var(--bevel-light), 6px 6px 0 rgba(58,42,24,.3);
    height: fit-content;
  }
  .titlebar {
    height: 30px; background: var(--peach);
    background-image: repeating-linear-gradient(var(--peach), var(--peach) 2px, #edb076 2px, #edb076 4px);
    border-bottom: 2px solid var(--peach-dark);
    display: flex; align-items: center; gap: 8px;
    padding: 0 10px; color: #5a2a0c; font-size: 13px;
  }
  .titlebar .t { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .dot-r, .dot-y { width: 10px; height: 10px; border: 2px solid var(--ink); display: inline-block; }
  .dot-r { background: #e07b6a; }
  .dot-y { background: #f2cf4a; }
  .titlebar .x {
    width: 20px; height: 18px; text-decoration: none;
    background: var(--cream); border: 2px solid var(--ink);
    color: var(--ink); font-size: 12px; line-height: 14px; text-align: center;
    box-shadow: inset 1px 1px 0 var(--bevel-light);
  }
  .titlebar .x:hover { background: #f2a3a3; }
  .toolbar {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 10px; background: var(--cream-2);
    border-bottom: 2px solid var(--cocoa);
  }
  .nav-btn {
    width: 26px; height: 22px; text-align: center; line-height: 20px;
    background: var(--cream); border: 2px solid var(--ink);
    color: var(--ink); font-size: 11px; text-decoration: none;
    box-shadow: inset 1px 1px 0 var(--bevel-light);
  }
  .nav-btn:hover { background: var(--peach); }
  .nav-btn:focus-visible, .titlebar .x:focus-visible { outline: 2px dashed var(--ink); outline-offset: 1px; }
  .nav-btn.dis { opacity: .4; pointer-events: none; }
  .addr {
    flex: 1; font-size: 12px; color: var(--cocoa);
    background: #fff; border: 2px solid var(--cocoa);
    padding: 3px 10px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }

  .page-body { padding: 22px clamp(14px, 4vw, 40px) 30px; }
  .post-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; font-size: 12px; }
  .cat-badge {
    color: var(--ink); border: 2px solid var(--ink);
    padding: 2px 10px; font-size: 12px;
  }
  .series-badge { color: var(--cocoa); }
  .date { color: var(--cocoa); margin-left: auto; }
  .post-title { font-size: 24px; margin: 14px 0 6px; line-height: 1.4; }
  .book-info {
    margin: 0 0 8px; font-size: 13px; color: var(--cocoa-dark);
    padding: 4px 10px; background: var(--cream-2);
    border: 2px dashed var(--cocoa); display: inline-block;
  }
  .post-summary { color: var(--cocoa); margin: 0 0 10px; }
  .rule { border: none; border-top: 2px dashed var(--cocoa); margin: 16px 0; }
  .post-footer { display: flex; gap: 10px; margin-top: 6px; }
  .post-footer .start-btn { text-decoration: none; }

  /* ===== 함께 들은 노래 (카세트 위젯) ===== */
  .music { margin-top: 18px; }
  .music-title {
    font-family: var(--font-pixel); font-size: 15px;
    margin: 0 0 12px; padding: 4px 10px;
    background: var(--cream-2); border-left: 5px solid var(--peach);
  }
  .music-list {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px;
  }
  .cassette {
    border: 3px solid var(--ink); background: var(--cream);
    box-shadow: 3px 3px 0 rgba(58,42,24,.28);
  }
  .cassette-shell { padding: 10px 12px 8px; background: var(--cream-2); border-bottom: 2px solid var(--ink); }
  .cassette-window {
    display: flex; align-items: center; gap: 8px;
    background: #3a2a18; border: 2px solid var(--ink);
    padding: 6px 12px; margin-bottom: 8px;
  }
  .reel {
    width: 22px; height: 22px; flex: none;
    border: 3px solid var(--cream); border-radius: 50%;
    background:
      conic-gradient(var(--cream) 0 25deg, transparent 25deg 90deg,
        var(--cream) 90deg 115deg, transparent 115deg 180deg,
        var(--cream) 180deg 205deg, transparent 205deg 270deg,
        var(--cream) 270deg 295deg, transparent 295deg 360deg);
    animation: reel-spin 3.5s linear infinite;
  }
  .tape-line { flex: 1; height: 3px; background: #8a6f55; }
  @keyframes reel-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .reel { animation: none; } }
  .cassette-label { display: flex; flex-direction: column; gap: 2px; }
  .song-title { font-size: 14px; color: var(--ink); font-weight: 700; }
  .song-artist { font-size: 12px; color: var(--cocoa-dark); }
  .music-meta {
    display: flex; align-items: center; gap: 8px; flex-wrap: wrap;
    padding: 8px 12px;
  }
  .music-note { font-size: 12px; color: var(--cocoa); flex: 1; min-width: 0; }
  .music-play {
    margin-left: auto; text-decoration: none; font-size: 11px;
    color: var(--ink); background: var(--cream); border: 2px solid var(--ink);
    padding: 3px 10px; box-shadow: inset 1px 1px 0 var(--bevel-light);
  }
  .music-play:hover { background: var(--peach); }
  .music-play:focus-visible { outline: 2px dashed var(--ink); outline-offset: 1px; }

  /* ===== 첨부파일 ===== */
  .attachments { margin-top: 18px; }
  .attach-title {
    font-family: var(--font-pixel); font-size: 15px;
    margin: 0 0 12px; padding: 4px 10px;
    background: var(--cream-2); border-left: 5px solid var(--peach);
  }
  .attach-list {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 14px;
  }
  .attach-item {
    border: 3px solid var(--ink); background: var(--cream);
    box-shadow: 3px 3px 0 rgba(58,42,24,.28);
    display: flex; flex-direction: column;
  }
  .attach-thumb {
    position: relative; display: block; width: 100%; padding: 0;
    border: none; border-bottom: 2px solid var(--ink);
    background: var(--cream-2); cursor: pointer; overflow: hidden;
    aspect-ratio: 4 / 3;
  }
  .attach-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .attach-fileicon {
    display: flex; align-items: center; justify-content: center;
    width: 100%; height: 100%;
    font-family: var(--font-pixel); font-size: 22px; color: var(--cocoa);
  }
  .attach-zoom {
    position: absolute; inset: auto 0 0 0;
    background: rgba(58,42,24,.78); color: var(--cream);
    font-size: 11px; padding: 3px 0; text-align: center;
    opacity: 0; transition: opacity .12s;
  }
  .attach-thumb:hover .attach-zoom,
  .attach-thumb:focus-visible .attach-zoom { opacity: 1; }
  .attach-thumb:focus-visible { outline: 2px dashed var(--ink); outline-offset: -4px; }
  .attach-meta { display: flex; flex-direction: column; gap: 6px; padding: 8px 10px; }
  .attach-label { font-size: 12px; line-height: 1.4; color: var(--ink); }
  .attach-dl {
    align-self: flex-start; text-decoration: none; font-size: 11px;
    color: var(--ink); background: var(--cream); border: 2px solid var(--ink);
    padding: 3px 8px; box-shadow: inset 1px 1px 0 var(--bevel-light);
  }
  .attach-dl:hover { background: var(--peach); }
  .attach-dl:focus-visible { outline: 2px dashed var(--ink); outline-offset: 1px; }

  /* ===== 라이트박스(미리보기) ===== */
  .lightbox {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(40,28,16,.82);
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 24px 16px;
  }
  .lightbox[hidden] { display: none; }
  .lb-titlebar {
    width: min(900px, 100%); display: flex; align-items: center; gap: 10px;
    background: var(--peach);
    background-image: repeating-linear-gradient(var(--peach), var(--peach) 2px, #edb076 2px, #edb076 4px);
    border: 3px solid var(--ink); border-bottom: none;
    padding: 6px 10px; color: #5a2a0c; font-size: 13px;
  }
  .lb-name { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .lb-dl {
    text-decoration: none; font-size: 11px; color: var(--ink);
    background: var(--cream); border: 2px solid var(--ink); padding: 2px 8px;
  }
  .lb-dl:hover { background: #f2cf4a; }
  .lb-x {
    width: 22px; height: 20px; cursor: pointer;
    background: var(--cream); border: 2px solid var(--ink);
    color: var(--ink); font-size: 12px; line-height: 14px;
  }
  .lb-x:hover { background: #f2a3a3; }
  .lb-stage {
    width: min(900px, 100%); flex: 1; min-height: 0;
    background: var(--cream); border: 3px solid var(--ink);
    display: flex; align-items: center; justify-content: center; overflow: auto;
  }
  .lb-stage img { max-width: 100%; max-height: 78vh; object-fit: contain; display: block; }
  .lb-stage iframe { width: 100%; height: 78vh; border: none; background: #fff; }

  @media (max-width: 640px) {
    .browser-desk { padding: 10px 6px 24px; }
    .titlebar .t { font-size: 12px; }
    .attach-list { grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); }
  }
</style>
